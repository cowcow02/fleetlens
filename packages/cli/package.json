{
  "name": "fleetlens",
  "version": "0.2.5",
  "description": "fleetlens — local-only dashboard and usage tracker for Claude Code sessions and agent fleets",
  "license": "MIT",
  "type": "module",
  "bin": {
    "fleetlens": "./dist/index.js"
  },
  "files": [
